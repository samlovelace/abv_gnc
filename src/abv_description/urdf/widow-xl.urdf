<robot name="widow-xl">

    <link name="base_link" />
    <joint name="mount_joint" type="fixed">
        <parent link="base_link" />
        <child link="shoulder_mount" />
        <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>

    <link name="shoulder_mount">
        <visual>
            <geometry>
                <mesh
                    filename="package://abv_description/meshes/widow-xl/shoulder_mount.dae"
                />
            </geometry>
        </visual>
    </link>

    <joint name="shoulder_joint" type="revolute">
        <parent link="shoulder_mount" />
        <child link="shoulder_link" />
        <origin
            xyz="0.0 0.0 0.0"
            rpy="0 0 0"
        />  <!-- offset to motor location -->
        <axis xyz="1 0 0" />
        <limit lower="-1.57" upper="1.57" effort="0" velocity="1.0" />
    </joint>

    <link name="shoulder_link">
        <visual>
            <geometry>
                <mesh
                    filename="package://abv_description/meshes/widow-xl/shoulder.dae"
                />
            </geometry>
        </visual>
    </link>

    <joint name="forearm_joint" type="revolute">
        <parent link="shoulder_link" />
        <child link="forearm_link" />
        <origin
            xyz="0.0 -0.0525 0.145"
            rpy="0 0 0"
        />  <!-- distance along shoulder link to elbow -->
        <axis xyz="1 0 0" />
        <limit lower="-1.57" upper="1.57" effort="0" velocity="1.0" />
    </joint>

    <link name="forearm_link">
        <visual>
            <geometry>
                <mesh
                    filename="package://abv_description/meshes/widow-xl/forearm.dae"
                />
            </geometry>
        </visual>
    </link>

    <joint name="wrist_joint" type="revolute">
        <parent link="forearm_link" />
        <child link="wrist_link" />
        <origin
            xyz="0 -0.15 0"
            rpy="0 0 0"
        />  <!-- distance along shoulder link to elbow -->
        <axis xyz="1 0 0" />
        <limit lower="-1.57" upper="1.57" effort="0" velocity="1.0" />
    </joint>

    <link name="wrist_link">
        <visual>
            <geometry>
                <mesh
                    filename="package://abv_description/meshes/widow-xl/wrist.dae"
                />
            </geometry>
        </visual>
    </link>

    <joint name="wrist_rotate_joint" type="revolute">
        <parent link="wrist_link" />
        <child link="wrist_rotate_link" />
        <origin
            xyz="0 -0.075 0"
            rpy="0 0 -1.57"
        />  <!-- distance along shoulder link to elbow -->
        <axis xyz="1 0 0" />
        <limit lower="-1.57" upper="1.57" effort="0" velocity="1.0" />
    </joint>

    <link name="wrist_rotate_link">
        <visual>
            <geometry>
                <mesh
                    filename="package://abv_description/meshes/widow-xl/wrist_rotate.dae"
                />
            </geometry>
        </visual>
    </link>
    <!-- Gripper base - fixed to wrist_rotate -->
        <joint name="gripper_joint" type="fixed">
            <parent link="wrist_rotate_link" />
            <child link="gripper_link" />
            <origin xyz="0.0575 0 0" rpy="0 0 0" />
        </joint>
        <link name="gripper_link" />

        <joint name="left_finger_joint" type="prismatic">
            <parent link="gripper_link" />
            <child link="left_finger_link" />
            <origin xyz="0 0.035 0" rpy="0 0 0" />
            <axis xyz="0 -1 0" />
            <limit lower="0.0" upper="0.0325" effort="10" velocity="1.0" />
        </joint>
        <link name="left_finger_link">
            <visual>
            <origin xyz="0 0 0" rpy="0 0 1.57" />  <!-- rotate mesh only -->
                <geometry>
                    <mesh
                    filename="package://abv_description/meshes/widow-xl/finger.dae"
                />
                </geometry>
            </visual>
        </link>

        <joint name="right_finger_joint" type="prismatic">
            <parent link="gripper_link" />
            <child link="right_finger_link" />
            <origin xyz="0 -0.035 0" rpy="0 0 0" />
            <axis xyz="0 1 0" />
            <limit lower="0.0" upper="0.0325" effort="10" velocity="1.0" />
        </joint>
        <link name="right_finger_link">
            <visual>
            <origin
                xyz="0 0 0"
                rpy="3.14159 0 -1.57"
            />  <!-- rotate mesh only -->
                <geometry>
                    <mesh
                    filename="package://abv_description/meshes/widow-xl/finger.dae"
                />
                </geometry>
            </visual>
        </link>

</robot>
