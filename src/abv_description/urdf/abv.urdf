<robot name="abv">

    <link name="base_link" />

    <!-- X translation -->
    <joint name="x_joint" type="prismatic">
        <parent link="base_link" />
        <child link="x_link" />
        <axis xyz="1 0 0" />
        <limit lower="-10.0" upper="10.0" effort="0" velocity="10.0" />
    </joint>
    <link name="x_link" />

    <!-- Y translation -->

    <joint name="y_joint" type="prismatic">
        <parent link="x_link" />
        <child link="y_link" />
        <axis xyz="0 1 0" />
        <limit lower="-10.0" upper="10.0" effort="0" velocity="10.0" />
    </joint>
    <link name="y_link" />

    <!-- Yaw rotation -->
    <joint name="yaw_joint" type="revolute">
        <parent link="y_link" />
        <child link="vehicle_link" />
        <axis xyz="0 0 1" />
        <limit lower="-3.14159" upper="3.14159" effort="0" velocity="10.0" />
    </joint>

    <!-- Actual vehicle link with mesh -->
    <link name="vehicle_link">
        <visual>
            <geometry>
                <mesh filename="package://abv_description/meshes/abv_v2.dae" />
            </geometry>
        </visual>
    </link>

</robot>
